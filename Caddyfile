6529vpn.io {
	# Access logs are intentionally not enabled here. If you add them later,
	# they must be redacted and purged within 1 hour.
	# API routes — reverse proxy to gateway container
	handle /auth/* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /vpn/* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /session/* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /subscription/* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /nodes* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /health {
		reverse_proxy 127.0.0.1:8080
	}
	handle /payout/* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /api/* {
		reverse_proxy 127.0.0.1:3002
	}

	# Everything else — static frontend with SPA fallback
	handle {
		root * /var/www/6529vpn
		try_files {path} /index.html
		file_server
	}
}

6529vpn.com {
	redir https://6529vpn.io{uri} permanent
}
