# Host-run zk-api
ZK_API_URL=http://host.docker.internal:3002
ZK_API_KEY=

# Shared gateway state
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=sovereign-vpn-rehearsal
SESSION_SIGNING_KEY=replace-with-a-long-random-secret
GATEWAY_FORWARDING_KEY=replace-with-a-second-long-random-secret

# Chain / access
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
MEMES_CONTRACT=0x33fd426905f149f8376e227d0c9d3340aad17af1
SUBSCRIPTION_MANAGER=
ENABLE_FREE_TIER=false

# Browser origin allowed by gateways
CORS_ORIGIN=http://127.0.0.1:5173

# Gateway A
GW_A_HTTP_PORT=8081
GW_A_WG_ENDPOINT_PORT=51821
GW_A_PUBLIC_URL=http://127.0.0.1:8081
GW_A_FORWARD_URL=http://gateway-a:8080
GW_A_SERVER_IP=10.80.1.1/24
GW_A_SUBNET=10.80.1.0/24
GW_A_INSTANCE_ID=gw-a

# Gateway B
GW_B_HTTP_PORT=8082
GW_B_WG_ENDPOINT_PORT=51822
GW_B_PUBLIC_URL=http://127.0.0.1:8082
GW_B_FORWARD_URL=http://gateway-b:8080
GW_B_SERVER_IP=10.80.2.1/24
GW_B_SUBNET=10.80.2.0/24
GW_B_INSTANCE_ID=gw-b
