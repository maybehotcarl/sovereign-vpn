# Copy this file to /root/sovereign-vpn/deploy/public-alerts.env on the droplet
# and fill in the real webhook destination. The systemd service will also read
# /root/sovereign-vpn/site-app/6529-zk-api/.env.production.local, so the same
# ALERT_WEBHOOK_URL can be shared between zk-api alerts and public-stack alerts.

PUBLIC_SITE_URL=https://6529vpn.io
PUBLIC_ALERT_ENV=production
PUBLIC_ALERT_SERVICE_NAME=6529-public-stack

# Leave blank when the alert runner is being installed but the destination has
# not been provisioned yet. Once this is set, the timer will begin sending
# failure and recovery alerts.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_BEARER_TOKEN=

# Optional: run local service checks over SSH when invoking the runner from a
# workstation. Leave blank on the droplet systemd timer.
PUBLIC_ALERT_REMOTE_HOST=

PUBLIC_ALERT_GATEWAY_SERVICE_NAME=sovereign-gateway
PUBLIC_ALERT_ZK_API_SERVICE_NAME=sovereign-zk-api
PUBLIC_ALERT_WG_INTERFACE=wg0

PUBLIC_ALERT_HTTP_TIMEOUT_SECONDS=15
PUBLIC_ALERT_COMMAND_TIMEOUT_SECONDS=15
PUBLIC_ALERT_SSH_CONNECT_TIMEOUT_SECONDS=10
PUBLIC_ALERT_COOLDOWN_SECONDS=900

PUBLIC_ALERT_EXPECT_ANONYMOUS_ENABLED=true
PUBLIC_ALERT_REQUIRE_SHARED_STATE_OK=false
PUBLIC_ALERT_CHECK_SESSION_INFO=true
PUBLIC_ALERT_CHECK_SUBSCRIPTION_TIERS=true

PUBLIC_ALERT_STATE_FILE=/var/lib/sovereign-vpn/public-alert-state.json
