# Ethereum RPC
ETH_RPC_URL=https://sepolia.infura.io/v3/YOUR_KEY
CHAIN_ID=11155111

# Contract addresses
PAYOUT_VAULT_ADDRESS=0x...
NODE_REGISTRY_ADDRESS=0x...

# Executor wallet (processes payouts from vault)
EXECUTOR_PRIVATE_KEY=0x...

# RAILGUN config
RAILGUN_MNEMONIC="word1 word2 ..."
WETH_ADDRESS=0xfff9976782d46cc05630d1f6ebab18b2324d6b14
RAILGUN_DB_PATH=./data/railgun-db
RAILGUN_ARTIFACTS_PATH=./data/railgun-artifacts
RAILGUN_POI_NODES=

# Payout schedule
PAYOUT_CRON=0 0 * * 0
MIN_PAYOUT_WEI=10000000000000000

# Dry run mode (log but don't execute)
DRY_RUN=true

# Health check
HEALTH_PORT=3001
